# .env.local — copy this to .env.local and fill in values
# This file is safe to commit — it contains no secrets

# API base URL (leave blank to use Next.js API routes)
NEXT_PUBLIC_API_URL=

# App URL (used for auth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Firebase / Clerk / Auth0 config
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Secret for JWT signing (server-side only — never expose to client)
# AUTH_SECRET=change-me-in-production
